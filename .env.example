# ==============================
# Backend (FastAPI)
# ==============================
# Required for AI features. Leave empty to run without AI.
OPENROUTER_API_KEY=

# OpenRouter API base URL.
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Backend server settings.
HOST=0.0.0.0
PORT=8000
# Keep false by default; enable only for local debugging.
DEBUG=false

# Optional explicit CORS origin list.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Archy runtime paths and service port.
ARCHY_LINK_PORT=47291
ARCHY_OUTPUT_DIR=~/.archy/projects

# Default model list exposed by the backend.
AVAILABLE_MODELS=anthropic/claude-sonnet-4-5,openai/gpt-4o,google/gemini-2.0-flash-001,qwen/qwen3-coder:free,google/gemma-4-31b-it:free,meta-llama/llama-3.1-405b

# ==============================
# Frontend (Vite)
# ==============================
# API URL used by frontend/src/utils/api.ts
VITE_API_URL=http://localhost:8000

# API URL used by frontend/src/services/apiClient.ts and APIConfig.tsx
VITE_BACKEND_URL=http://localhost:8000