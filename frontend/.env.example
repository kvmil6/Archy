# Frontend-only environment template for Archy (Vite)
# Do not place secrets in frontend env files. Variables prefixed with VITE_ are exposed to the browser.

# Primary API endpoint used by frontend/src/utils/api.ts
VITE_API_URL=http://localhost:8000

# API endpoint used by frontend/src/services/apiClient.ts and APIConfig.tsx
VITE_BACKEND_URL=http://localhost:8000
